# Copy to `.env.<your-firebase-project-id>` (non-secret config) and/or `.env` (secrets), then redeploy:
#   npm run firebase:deploy
#
# Production (`.env.em-fit-system-c0d3d` in repo):
#   ALLOW_DEV_SUBSCRIPTION=false
#   GOOGLE_PLAY_PACKAGE_NAME=com.jorgeitglobalsolutionssorganization.emfitsystem
#   IAP_SKU_MONTHLY=em_fit_monthly
#   IAP_SKU_YEARLY=em_fit_yearly
#
# Secrets: Put the Play Console–linked service account key in gitignored `.env`:
#   GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# (minified single-line JSON; do not commit private keys)
#
# QA only — do NOT enable in production store releases:
# ALLOW_DEV_SUBSCRIPTION=true

# Never enable in production:
# ALLOW_VERIFY_PURCHASE_STUB=true

# Optional: Apple IAP verification (iOS)
# APPLE_IOS_BUNDLE_ID=com.jorgeitglobalsolutionssorganization.emfitsystem
