{
  "expo": {
    "name": "EM Fit System",
    "slug": "em-fit-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jorgeitglobalsolutionssorganization.emfitsystem",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jorgeitglobalsolutionssorganization.emfitsystem",
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "versionCode": 10
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-iap",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "extra": {
      "useMockData": false,
      "firebaseFunctionsRegion": "us-central1",
      "eas": {
        "projectId": "23d75ead-2ffa-4de0-978a-4f95e2ba2f0b"
      },
      "iapSkuMonthly": "em_fit_monthly",
      "iapSkuYearly": "em_fit_yearly",
      "legalTermsUrl": "https://estaciondemusculacion.com/terms",
      "legalPrivacyUrl": "https://estaciondemusculacion.com/privacy",
      "supportEmail": "cesar@estaciondemusculacion.com"
    },
    "owner": "jorgeitglobalsolutionss-organization"
  }
}
