{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "exercises:generate": "node scripts/generateExercisesCatalog.mjs",
    "exercises:upload": "node firebase/functions/scripts/uploadExerciseGifs.mjs",
    "firebase:deploy": "npm --prefix firebase/functions run build && cross-env FUNCTIONS_DISCOVERY_TIMEOUT=60 npx firebase-tools deploy --only firestore,functions,storage --config firebase/firebase.json",
    "firebase:deploy:functions": "npm --prefix firebase/functions run build && cross-env FUNCTIONS_DISCOVERY_TIMEOUT=60 npx firebase-tools deploy --only functions --config firebase/firebase.json",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules --config firebase/firebase.json",
    "firebase:deploy:storage": "npx firebase-tools deploy --only storage --config firebase/firebase.json",
    "eas:build:android": "eas build --platform android --profile production",
    "release:check": "node scripts/releaseSmokeCheck.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-iap": "^4.2.1",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "^56.0.6",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.1",
    "i18next": "^26.3.2",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "firebase-tools": "^15.16.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
